# PostgreSQL (required). Use the password you set when installing PostgreSQL.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/inspection_app

# First-time setup (after updating DATABASE_URL):
#   npm run setup
# Then start the app:
#   npm run dev
# Demo login: inspector@tba.com / password123 (Inspector Demo button on login page)

# Optional: session/JWT signing (defaults exist for dev)
# SESSION_SECRET=your-long-random-string

# Optional: app port (default 3000)
# PORT=3000

# Optional: Google Maps features
# GOOGLE_MAPS_API_KEY=
